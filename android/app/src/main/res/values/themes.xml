<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.LifeOS" parent="android:Theme.Material.NoActionBar">
        <!-- Make system bars transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Use light icons for dark background -->
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Premium dark window background -->
        <item name="android:windowBackground">#121318</item>
    </style>
</resources>